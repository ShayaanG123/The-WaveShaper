`timescale 1ns / 1ps

module two_complement_to_offset #(
    parameter int WIDTH = 32
) (
    // Input is your standard signed DSP audio
    input  logic signed [WIDTH-1:0] data_in,

    // Output is the unsigned/offset format for the DAC driver
    output logic        [WIDTH-1:0] data_out
);

    // To convert 2's complement to offset binary,
    // we simply invert the Most Significant Bit (MSB).
    assign data_out = { ~data_in[WIDTH-1], data_in[WIDTH-2:0] };

endmodule
