module Chamberlin_SVF
    #(
        parameter int AUDIO_WIDTH = 24,
        parameter int COEF_WIDTH  = 16,
        parameter int ACC_WIDTH   = 40, // AUDIO_WIDTH + COEF_WIDTH
        parameter int Q_FRACT     = 15  // Assuming Q1.15 for F and Damp
    )
    (
        input  logic clk,
        input  logic rst,
        input  logic en,                // Audio rate pulse (e.g., 48kHz)
        
        input  logic signed [COEF_WIDTH-1:0]  F,
        input  logic signed [COEF_WIDTH-1:0]  Damp,
        input  logic signed [AUDIO_WIDTH-1:0] signal_in,
        
        output logic signed [AUDIO_WIDTH-1:0] HP,
        output logic signed [AUDIO_WIDTH-1:0] LP,
        output logic signed [AUDIO_WIDTH-1:0] BP,
        output logic signed [AUDIO_WIDTH-1:0] Notch
    );

    // --- State Registers (The z^-1 delays) ---
    logic signed [AUDIO_WIDTH-1:0] BP_reg, LP_reg;
    
    // --- Intermediate Signals for Combinational Chain ---
    logic signed [ACC_WIDTH-1:0]   hp_full, bp_full, lp_full;
    // Added notch_next here:
    logic signed [AUDIO_WIDTH-1:0] hp_next, bp_next, lp_next, notch_next; 
    logic signed [AUDIO_WIDTH:0]   notch_full; // Extra bit for addition
    
    // --- Saturation Constants ---
    localparam signed [AUDIO_WIDTH-1:0] MAX_VAL = (1 << (AUDIO_WIDTH-1)) - 1;
    localparam signed [AUDIO_WIDTH-1:0] MIN_VAL = -(1 << (AUDIO_WIDTH-1));

    // --- Combinational Datapath (Single-Cycle Cascade) ---
    always_comb begin
        // 1. High-Pass: HP[n] = x[n] - LP[n-1] - (Damp * BP[n-1])
        // Arithmetic shift right (>>>) handles the Q-format division
        hp_full = signal_in - LP_reg - ((Damp * BP_reg) >>> Q_FRACT);
        
        // Clamp HP
        if      (hp_full > MAX_VAL) hp_next = MAX_VAL;
        else if (hp_full < MIN_VAL) hp_next = MIN_VAL;
        else                        hp_next = hp_full[AUDIO_WIDTH-1:0];

        // 2. Band-Pass: BP[n] = BP[n-1] + (F * HP[n])
        bp_full = BP_reg + ((F * hp_next) >>> Q_FRACT);
        
        // Clamp BP
        if      (bp_full > MAX_VAL) bp_next = MAX_VAL;
        else if (bp_full < MIN_VAL) bp_next = MIN_VAL;
        else                        bp_next = bp_full[AUDIO_WIDTH-1:0];

        // 3. Low-Pass: LP[n] = LP[n-1] + (F * BP[n])
        lp_full = LP_reg + ((F * bp_next) >>> Q_FRACT);
        
        // Clamp LP
        if      (lp_full > MAX_VAL) lp_next = MAX_VAL;
        else if (lp_full < MIN_VAL) lp_next = MIN_VAL;
        else                        lp_next = lp_full[AUDIO_WIDTH-1:0];
        
        // 4. Notch: HP[n] + LP[n]
        notch_full = hp_next + lp_next;
        
        // Clamp Notch (Fixed syntax and typos)
        if      (notch_full > MAX_VAL) notch_next = MAX_VAL;
        else if (notch_full < MIN_VAL) notch_next = MIN_VAL;
        else                           notch_next = notch_full[AUDIO_WIDTH-1:0];
    end
    
    // --- Sequential State Updates ---
    always_ff @(posedge clk) begin
        if (rst) begin
            BP_reg <= '0;
            LP_reg <= '0;
        end else if (en) begin
            BP_reg <= bp_next;
            LP_reg <= lp_next;
        end
    end
    
    // --- Output Assignments (Fixed case sensitivity) ---
    assign HP    = hp_next;
    assign BP    = bp_next; 
    assign LP    = lp_next;
    assign Notch = notch_next;

endmodule