module clock_count (
    input  logic CLOCK_50,
    input  logic reset,
    output logic aclk
);

    // 50MHz / 48kHz = 1041.66...
    // We use 1042 as the divisor. 
    // To toggle the clock, we count to half that value: 521.
    localparam int DIVISOR = 1042;
    localparam int HALF_DIVISOR = DIVISOR / 2;
    
    // We need 11 bits to count up to 1042 (2^10 = 1024, 2^11 = 2048)
    logic [10:0] count;

    always_ff @(posedge CLOCK_50 or posedge reset) begin
        if (reset) begin
            count <= '0;
            aclk  <= 1'b0;
        end else begin
            if (count >= (HALF_DIVISOR - 1)) begin
                count <= '0;
                aclk  <= ~aclk; // Toggle the output clock
            end else begin
                count <= count + 1'b1;
            end
        end
    end

endmodule